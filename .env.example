# Alpaca Paper Trading API Credentials
ALPACA_API_KEY=<Your key>
ALPACA_SECRET_KEY=<Your secret key>
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_DATA_URL=https://data.alpaca.markets/v2

# Trading Configuration
TICKERS=SPY,QQQ,AAPl,MSFT,AMZN,IWM
MODE=live
MAX_RISK_PCT=0.02
MIN_CREDIT_RATIO=0.33
MAX_DELTA=0.20
DRY_RUN=false

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs
TRADE_PLAN_DIR=trade_plans

# Intelligence Layer (LLM + RAG)
# Set LLM_ENABLED=true after running: ollama pull mistral && ollama pull nomic-embed-text
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=mistral
LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
TRADE_JOURNAL_DIR=trade_journal
KNOWLEDGE_BASE_DIR=knowledge_base
